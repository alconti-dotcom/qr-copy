<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR Code Grid</title>
    <!-- Script to generate QR codes automatically -->
    <script src="https://cloudflare.com"></script>
    <style>
        body { font-family: sans-serif; background: #f4f4f9; padding: 20px; margin: 0; }
        h1 { text-align: center; color: #333; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; max-width: 1200px; margin: 0 auto; }
        .card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: space-between; }
        .qr-box { margin: 15px 0; background: #eee; padding: 10px; border-radius: 8px; }
        .text-preview { font-weight: bold; color: #555; margin-bottom: 15px; word-break: break-word; }
        button { background: #28a745; color: white; border: none; padding: 10px 20px; font-size: 14px; border-radius: 6px; cursor: pointer; width: 100%; transition: background 0.2s; }
        button:hover { background: #218838; }
    </style>
</head>
<body>

<h1>Scan QR to Visit or Click to Copy</h1>
<div class="grid" id="cardGrid"></div>

<script>
// 1. Define your 9 different texts here
const textItems = [
    "Text Item Number One",
    "Text Item Number Two",
    "Text Item Number Three",
    "Text Item Number Four",
    "Text Item Number Five",
    "Text Item Number Six",
    "Text Item Number Seven",
    "Text Item Number Eight",
    "Text Item Number Nine"
];

const grid = document.getElementById("cardGrid");
const currentUrl = window.location.href.split('?')[0]; // Gets base URL without parameters

// 2. Dynamically generate the 9 cards
textItems.forEach((text, index) => {
    const itemId = index + 1;
    
    // Create a unique link for this specific item using URL parameters
    // Example: https://yourwebsite.com
    const itemTargetUrl = `${currentUrl}?item=${itemId}`;

    // Create the HTML structure for the card
    const card = document.createElement("div");
    card.className = "card";
    card.innerHTML = `
        <div class="text-preview">Text #${itemId}: "${text}"</div>
        <div class="qr-box" id="qr-${itemId}"></div>
        <button onclick="copyToClipboard('${text.replace(/'/g, "\\'")}')">Copy Text #${itemId}</button>
    `;
    grid.appendChild(card);

    // Generate the QR code inside the card pointing to its specific link
    new QRCode(document.getElementById(`qr-${itemId}`), {
        text: itemTargetUrl,
        width: 150,
        height: 150
    });
});

// 3. Handle Clipboard copy action
function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
        alert(`Copied: "${text}"`);
    }).catch(err => {
        console.error("Copy failed", err);
    });
}

// 4. Auto-copy if someone scanned a specific QR code
window.onload = function() {
    const urlParams = new URLSearchParams(window.location.search);
    const scannedItem = urlParams.get('item');
    
    if (scannedItem) {
        const itemIndex = parseInt(scannedItem) - 1;
        if (textItems[itemIndex]) {
            const targetText = textItems[itemIndex];
            
            // Show a prompt reminding the user to tap to copy (Browser security requirement)
            alert(`You scanned QR #${scannedItem}! Tap OK to copy the text.`);
            copyToClipboard(targetText);
        }
    }
};
</script>

</body>
</html>
